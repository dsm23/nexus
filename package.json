{
  "name": "nexus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "author": "Praveen Sripati",
  "description": "A comprehensive, modern intranet dashboard built with React, TypeScript, and Tailwind CSS",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "fmt": "oxfmt . --write",
    "fmt.check": "oxfmt . --check",
    "lint:js": "oxlint . --report-unused-disable-directives --deny-warnings",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input",
    "lint": "run-p lint:js lint:css",
    "preview": "vite preview",
    "test": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
