    "lucide-react": "1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-organizational-chart": "2.2.1",
    "react-router-dom": "7.18.0",
    "recharts": "3.8.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@commitlint/cli": "21.0.2",
